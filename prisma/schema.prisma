// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  phone           String?
  password        String
  college         String
  collegeEmail    String    @unique
  isVerified      Boolean   @default(false)
  verificationStep Int      @default(1) // 1: Registration, 2: Email OTP, 3: ID OCR, 4: Video, 5: Complete
  credits         Float     @default(0)
  skills          String[]  // Skills they can teach
  interests       String[]  // Skills they want to learn
  bio             String?
  avatarUrl       String?
  collegeIdUrl    String?
  videoUrl        String?
  rating          Float     @default(0)
  numReviews      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessionsAsMentor Session[] @relation("MentorSessions")
  sessionsAsStudent Session[] @relation("StudentSessions")
  transactions     Transaction[]
  reviewsGiven     Review[]  @relation("Reviewer")
  reviewsReceived  Review[]  @relation("Reviewee")
}

model Session {
  id               String   @id @default(uuid())
  mentorId         String
  studentId        String
  skill            String
  type             SessionType
  status           SessionStatus @default(SCHEDULED)
  startTime        DateTime?
  endTime          DateTime?
  creditsTransferred Float  @default(0)
  roomId           String   @unique
  createdAt        DateTime @default(now())

  mentor           User     @relation("MentorSessions", fields: [mentorId], references: [id])
  student          User     @relation("StudentSessions", fields: [studentId], references: [id])
  reviews          Review[]
}

model Transaction {
  id        String          @id @default(uuid())
  userId    String
  amount    Float
  type      TransactionType
  status    TransactionStatus @default(PENDING)
  timestamp DateTime        @default(now())

  user      User            @relation(fields: [userId], references: [id])
}

model Review {
  id          String   @id @default(uuid())
  sessionId   String
  reviewerId  String
  revieweeId  String
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  session     Session  @relation(fields: [sessionId], references: [id])
  reviewer    User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewee    User     @relation("Reviewee", fields: [revieweeId], references: [id])
}

enum SessionType {
  FREELANCE
  SWAP
}

enum SessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  PAYMENT
  EARNING
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}
